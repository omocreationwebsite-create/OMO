<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="theme-color" content="#ff4da6">
  <title>Staff Dashboard · Omocreations</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --primary: #ff4da6; --primary-dark: #e6398c; --primary-soft: #fff0f6; --dark: #0f0f1a; --gray: #6b7280; --gray-light: #f3f4f6; --success: #10b981; --warning: #f59e0b; --danger: #ef4444; --info: #3b82f6; --header-height: 64px; --sidebar-width: 280px; }
    body { font-family: 'Inter', sans-serif; background: #f9fafb; display: flex; min-height: 100vh; }
    .sidebar { width: var(--sidebar-width); background: linear-gradient(180deg, #0f0f1a 0%, #1a1a2e 100%); color: white; position: fixed; height: 100vh; overflow-y: auto; z-index: 100; }
    .sidebar-header { padding: 24px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .logo-icon { width: 40px; height: 40px; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 700; }
    .logo-text { font-size: 1.2rem; font-weight: 700; } .logo-text span { color: var(--primary); }
    .sidebar-nav { padding: 20px 12px; }
    .nav-item { display: flex; align-items: center; gap: 14px; padding: 12px 16px; border-radius: 14px; color: rgba(255,255,255,0.65); cursor: pointer; border: none; background: none; width: 100%; font-size: 0.9rem; font-weight: 500; margin-bottom: 4px; }
    .nav-item i { width: 22px; }
    .nav-item:hover { background: rgba(255,77,166,0.12); color: white; }
    .nav-item.active { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; }
    .nav-item.logout { color: rgba(239,68,68,0.7); margin-top: 20px; }
    .sidebar-footer { padding: 20px; border-top: 1px solid rgba(255,255,255,0.06); position: absolute; bottom: 0; width: 100%; background: inherit; }
    .user-profile { display: flex; align-items: center; gap: 12px; }
    .user-avatar { width: 44px; height: 44px; border-radius: 14px; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); display: flex; align-items: center; justify-content: center; font-weight: 700; }
    .user-details h4 { font-size: 0.9rem; } .user-details p { font-size: 0.7rem; opacity: 0.6; }
    .main-content { flex: 1; margin-left: var(--sidebar-width); }
    .top-bar { height: var(--header-height); background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(0,0,0,0.04); position: sticky; top: 0; z-index: 40; }
    .page-title { font-size: 1.4rem; font-weight: 700; color: var(--dark); }
    .content-wrapper { padding: 24px; max-width: 1400px; }
    
    .welcome-banner { background: linear-gradient(135deg, var(--primary-soft), white); border-radius: 20px; padding: 20px 24px; margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between; border: 1px solid rgba(255,77,166,0.15); }
    .welcome-text h2 { font-size: 1.4rem; font-weight: 700; color: var(--dark); }
    .welcome-text p { color: var(--gray); margin-top: 4px; }
    .points-display { text-align: right; }
    .points-value { font-size: 2.5rem; font-weight: 700; color: var(--primary); }
    .points-label { font-size: 0.8rem; color: var(--gray); }
    
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 24px; }
    .stat-card { background: white; padding: 20px; border-radius: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.04); }
    .stat-header { display: flex; justify-content: space-between; margin-bottom: 12px; }
    .stat-header span { font-size: 0.7rem; color: var(--gray); text-transform: uppercase; font-weight: 600; }
    .stat-icon { width: 40px; height: 40px; border-radius: 12px; background: var(--primary-soft); display: flex; align-items: center; justify-content: center; color: var(--primary); }
    .stat-value { font-size: 2rem; font-weight: 700; color: var(--dark); }
    .stat-sub { font-size: 0.7rem; color: var(--gray); margin-top: 4px; }
    
    .two-column { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
    .panel { background: white; border-radius: 20px; padding: 22px; box-shadow: 0 2px 8px rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.04); margin-bottom: 24px; }
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
    .panel-header h3 { font-size: 1rem; font-weight: 700; display: flex; align-items: center; gap: 8px; }
    .panel-header h3 i { color: var(--primary); }
    
    .announcement-card { background: var(--primary-soft); border-radius: 14px; padding: 14px; margin-bottom: 10px; border-left: 4px solid var(--primary); cursor: pointer; transition: all 0.15s; }
    .announcement-card:hover { transform: translateX(3px); }
    .announcement-card.unread { background: rgba(255,77,166,0.15); }
    .announcement-card h4 { font-size: 0.9rem; margin-bottom: 6px; display: flex; align-items: center; gap: 8px; }
    .announcement-card p { font-size: 0.8rem; color: var(--gray); margin-bottom: 6px; }
    .announcement-card .meta { font-size: 0.65rem; color: var(--gray); display: flex; justify-content: space-between; }
    
    .coin-transaction { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.04); }
    .coin-transaction:last-child { border-bottom: none; }
    .coin-info { display: flex; align-items: center; gap: 12px; }
    .coin-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
    .coin-icon.positive { background: rgba(16,185,129,0.1); color: var(--success); }
    .coin-icon.negative { background: rgba(239,68,68,0.1); color: var(--danger); }
    .coin-details p { font-weight: 600; font-size: 0.85rem; }
    .coin-details small { font-size: 0.7rem; color: var(--gray); }
    .coin-amount { font-weight: 700; font-size: 1rem; }
    .coin-amount.positive { color: var(--success); }
    .coin-amount.negative { color: var(--danger); }
    
    .task-item { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; border-bottom: 1px solid rgba(0,0,0,0.04); }
    .task-item:last-child { border-bottom: none; }
    .task-info h4 { font-size: 0.9rem; margin-bottom: 4px; }
    .task-info p { font-size: 0.7rem; color: var(--gray); }
    .task-deadline { font-size: 0.7rem; }
    .task-deadline.urgent { color: var(--danger); }
    .task-deadline.warning { color: var(--warning); }
    
    .badge { padding: 4px 10px; border-radius: 40px; font-size: 0.65rem; font-weight: 600; }
    .badge-success { background: rgba(16,185,129,0.1); color: var(--success); }
    .badge-warning { background: rgba(245,158,11,0.1); color: var(--warning); }
    .badge-danger { background: rgba(239,68,68,0.1); color: var(--danger); }
    .badge-info { background: rgba(59,130,246,0.1); color: var(--info); }
    
    .btn { padding: 8px 16px; border-radius: 40px; font-weight: 600; font-size: 0.75rem; border: none; cursor: pointer; background: white; border: 1px solid rgba(0,0,0,0.08); display: inline-flex; align-items: center; gap: 6px; transition: all 0.15s; }
    .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; border: none; }
    .btn-outline { border: 1.5px solid rgba(255,77,166,0.3); color: var(--primary); background: transparent; }
    .btn-sm { padding: 5px 12px; font-size: 0.7rem; }
    .btn-success { background: var(--success); color: white; }
    
    .empty-state { text-align: center; padding: 30px; color: var(--gray); }
    .empty-state i { font-size: 2rem; color: var(--primary-light); margin-bottom: 10px; opacity: 0.5; }
    
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center; z-index: 1000; padding: 16px; }
    .modal { background: white; border-radius: 28px; padding: 28px; max-width: 500px; width: 100%; max-height: 85vh; overflow-y: auto; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .modal-close { background: none; border: none; font-size: 1.3rem; cursor: pointer; color: var(--gray); }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--dark); margin-bottom: 6px; }
    .form-control { width: 100%; padding: 12px 16px; border: 1.5px solid rgba(0,0,0,0.08); border-radius: 14px; font-size: 0.9rem; outline: none; }
    textarea.form-control { resize: vertical; min-height: 80px; }
    .pin-input-container { display: flex; gap: 10px; justify-content: center; margin: 20px 0; }
    .pin-input { width: 55px; height: 65px; text-align: center; font-size: 1.8rem; font-weight: 700; border: 2px solid rgba(255,77,166,0.2); border-radius: 14px; }
    
    .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; }
    .toast { background: white; padding: 14px 20px; border-radius: 50px; box-shadow: 0 10px 30px rgba(0,0,0,0.12); display: flex; align-items: center; gap: 12px; transform: translateX(400px); transition: transform 0.25s; border-left: 4px solid var(--primary); margin-top: 10px; }
    .toast.show { transform: translateX(0); }
    
    .tabs-container { display: flex; gap: 6px; margin-bottom: 15px; background: var(--gray-light); padding: 5px; border-radius: 40px; }
    .tab-btn { padding: 8px 16px; border-radius: 40px; font-weight: 600; font-size: 0.75rem; border: none; background: none; color: var(--gray); cursor: pointer; flex: 1; }
    .tab-btn.active { background: var(--primary); color: white; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    
    .salary-summary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 16px; border-radius: 14px; margin-bottom: 15px; }
    .salary-row { display: flex; justify-content: space-between; padding: 6px 0; }
    .salary-row.total { border-top: 1px solid rgba(255,255,255,0.3); margin-top: 6px; padding-top: 10px; font-weight: 700; font-size: 1.1rem; }
    
    @media (max-width: 992px) { .two-column { grid-template-columns: 1fr; } .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 768px) { .sidebar { display: none; } .main-content { margin-left: 0; } .content-wrapper { padding: 16px; } .stats-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-header"><div class="logo-icon">✨</div><div class="logo-text"><span>Omo</span>creations</div></div>
  <nav class="sidebar-nav">
    <button class="nav-item active" onclick="window.location.href='staff-dashboard.html'"><i class="fas fa-chart-pie"></i><span>Dashboard</span></button>
    <button class="nav-item" onclick="window.location.href='profile.html'"><i class="fas fa-user"></i><span>My Profile</span></button>
    <button class="nav-item logout" id="logoutBtn"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
  </nav>
  <div class="sidebar-footer"><div class="user-profile"><div class="user-avatar" id="userAvatar">S</div><div class="user-details"><h4 id="userName">Staff</h4><p id="userRole">Staff</p></div></div></div>
</aside>

<main class="main-content">
  <header class="top-bar"><h1 class="page-title">Staff Dashboard</h1><div style="color:var(--gray);"><span id="currentDate"></span></div></header>
  
  <div class="content-wrapper">
    
    <!-- Welcome Banner -->
    <div class="welcome-banner">
      <div class="welcome-text">
        <h2>Welcome back, <span id="welcomeName">Staff</span>! 👋</h2>
        <p><span id="currentDay"></span> · Ready to crush your tasks today?</p>
      </div>
      <div class="points-display">
        <div class="points-value" id="totalPoints">0</div>
        <div class="points-label">Total Points · ₦<span id="pointValue">100</span>/pt</div>
      </div>
    </div>
    
    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-header"><span>Tasks Done</span><div class="stat-icon"><i class="fas fa-check-circle"></i></div></div><div class="stat-value" id="tasksDone">0</div><div class="stat-sub">This month</div></div>
      <div class="stat-card"><div class="stat-header"><span>Pending Tasks</span><div class="stat-icon"><i class="fas fa-clock"></i></div></div><div class="stat-value" id="pendingTasks">0</div><div class="stat-sub">In progress</div></div>
      <div class="stat-card"><div class="stat-header"><span>Leave Days</span><div class="stat-icon"><i class="fas fa-umbrella-beach"></i></div></div><div class="stat-value" id="leaveDays">2</div><div class="stat-sub">Remaining</div></div>
      <div class="stat-card"><div class="stat-header"><span>Attendance</span><div class="stat-icon"><i class="fas fa-calendar-check"></i></div></div><div class="stat-value" id="attendanceStreak">0</div><div class="stat-sub">Day streak</div></div>
    </div>
    
    <!-- Two Column Layout -->
    <div class="two-column">
      
      <!-- Left Column -->
      <div>
        <!-- Salary Overview -->
        <div class="panel">
          <div class="panel-header"><h3><i class="fas fa-money-bill-wave"></i> Salary Overview</h3></div>
          <div class="salary-summary" id="salarySummary">
            <div class="salary-row"><span>Base Salary</span><span id="salaryBase">₦0</span></div>
            <div class="salary-row"><span>Points Earned</span><span id="salaryPoints">0</span></div>
            <div class="salary-row"><span>Point Value</span><span>₦<span id="salaryPointValue">100</span>/pt</span></div>
            <div class="salary-row"><span>Points Bonus</span><span id="pointsBonus">₦0</span></div>
            <div class="salary-row total"><span>Estimated Salary</span><span id="finalSalary">₦0</span></div>
          </div>
        </div>
        
        <!-- Coin Transactions -->
        <div class="panel">
          <div class="panel-header"><h3><i class="fas fa-coins"></i> Recent Coin Transactions</h3></div>
          <div id="coinTransactionsList"></div>
        </div>
      </div>
      
      <!-- Right Column -->
      <div>
        <!-- Announcements -->
        <div class="panel">
          <div class="panel-header"><h3><i class="fas fa-bullhorn"></i> Announcements</h3><button class="btn btn-outline btn-sm" onclick="markAllAnnouncementsRead()"><i class="fas fa-check-double"></i> Mark All Read</button></div>
          <div class="tabs-container">
            <button class="tab-btn active" data-tab="general">General</button>
            <button class="tab-btn" data-tab="personal">Personal</button>
          </div>
          <div id="generalAnnouncements" class="tab-content active" style="max-height: 300px; overflow-y: auto;"></div>
          <div id="personalAnnouncements" class="tab-content" style="max-height: 300px; overflow-y: auto;"></div>
        </div>
      </div>
    </div>
    
    <!-- My Tasks -->
    <div class="panel">
      <div class="panel-header"><h3><i class="fas fa-tasks"></i> My Assigned Tasks</h3></div>
      <div class="tabs-container">
        <button class="tab-btn active" data-task-tab="available"><i class="fas fa-list"></i> Available</button>
        <button class="tab-btn" data-task-tab="inprogress"><i class="fas fa-spinner"></i> In Progress</button>
        <button class="tab-btn" data-task-tab="completed"><i class="fas fa-check-circle"></i> Completed</button>
      </div>
      
      <div id="availableTasks" class="tab-content active"></div>
      <div id="inprogressTasks" class="tab-content"></div>
      <div id="completedTasks" class="tab-content"></div>
    </div>
    
    <!-- Recent Attendance -->
    <div class="panel">
      <div class="panel-header"><h3><i class="fas fa-calendar-alt"></i> Recent Attendance</h3></div>
      <div class="table-wrapper">
        <table style="width:100%; border-collapse:collapse;">
          <thead><tr style="border-bottom:1.5px solid var(--primary-soft);"><th style="text-align:left;padding:10px;font-size:0.7rem;color:var(--gray);">Date</th><th style="text-align:left;padding:10px;font-size:0.7rem;color:var(--gray);">Check-in</th><th style="text-align:left;padding:10px;font-size:0.7rem;color:var(--gray);">Status</th></tr></thead>
          <tbody id="attendanceTable"></tbody>
        </table>
      </div>
    </div>
    
    <!-- Request Leave -->
    <div class="panel">
      <div class="panel-header"><h3><i class="fas fa-calendar-plus"></i> Request Leave</h3></div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <input type="date" id="leaveStart" class="form-control" style="flex:1;">
        <input type="date" id="leaveEnd" class="form-control" style="flex:1;">
        <button class="btn btn-primary" id="requestLeaveBtn">Request Leave</button>
      </div>
      <p style="font-size:0.7rem;color:var(--gray);margin-top:10px;">Max 2 days per month. Admin approval required.</p>
    </div>
    
  </div>
</main>

<div class="modal-overlay" id="modalOverlay"><div class="modal"><div class="modal-header"><h3 id="modalTitle">Modal</h3><button class="modal-close" onclick="hideModal()">&times;</button></div><div id="modalContent"></div></div></div>
<div class="toast-container" id="toastContainer"></div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getAuth, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
  import { getFirestore, doc, getDoc, collection, query, where, orderBy, limit, onSnapshot, addDoc, updateDoc, serverTimestamp, getDocs, increment, arrayUnion } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  const firebaseConfig = { apiKey: "AIzaSyA_JPUfHVotadGfntwk8qQXFp64pvDfTRI", authDomain: "fashion-46e5d.firebaseapp.com", projectId: "fashion-46e5d", storageBucket: "fashion-46e5d.firebasestorage.app", messagingSenderId: "408062284317", appId: "1:408062284317:web:eb905bce68926c10a0ecf4" };
  const app = initializeApp(firebaseConfig); const auth = getAuth(app); const db = getFirestore(app);
  let currentUser = null, userData = null, globalPointValue = 500, unsubscribes = [];

  function formatDate(d) { if (!d) return '-'; const date = d.toDate ? d.toDate() : new Date(d); return date.toLocaleDateString('en-GB', {day:'2-digit',month:'short'}); }
  function formatTime(d) { if (!d) return '-'; const date = d.toDate ? d.toDate() : new Date(d); return date.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'}); }
  function formatDateTime(d) { if (!d) return '-'; const date = d.toDate ? d.toDate() : new Date(d); return date.toLocaleString('en-GB', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}); }
  function formatCurrency(n) { return '₦' + (n || 0).toLocaleString(); }
  function showToast(msg, type='success') { const c = document.getElementById('toastContainer'); const t = document.createElement('div'); t.className = `toast ${type}`; t.innerHTML = `<i class="fas fa-${type==='success'?'check-circle':'exclamation-circle'}"></i><span>${msg}</span>`; c.appendChild(t); setTimeout(() => t.classList.add('show'), 10); setTimeout(() => t.remove(), 4000); }
  window.hideModal = () => document.getElementById('modalOverlay').style.display = 'none';
  function showModal(title, content) { document.getElementById('modalTitle').textContent = title; document.getElementById('modalContent').innerHTML = content; document.getElementById('modalOverlay').style.display = 'flex'; }

  // Tab switching
  document.querySelectorAll('[data-tab]').forEach(t => t.addEventListener('click', function() {
    const container = this.closest('.panel') || document;
    container.querySelectorAll('[data-tab]').forEach(x => x.classList.remove('active'));
    this.classList.add('active');
    container.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    document.getElementById(this.dataset.tab + 'Announcements').classList.add('active');
  }));

  document.querySelectorAll('[data-task-tab]').forEach(t => t.addEventListener('click', function() {
    document.querySelectorAll('[data-task-tab]').forEach(x => x.classList.remove('active'));
    this.classList.add('active');
    document.querySelectorAll('#availableTasks, #inprogressTasks, #completedTasks').forEach(c => c.classList.remove('active'));
    document.getElementById(this.dataset.taskTab + 'Tasks').classList.add('active');
  }));

  function loadDashboard() {
    if (!currentUser) return;
    cleanupSubscriptions();
    
    // User data
    unsubscribes.push(onSnapshot(doc(db, 'users', currentUser.uid), (snap) => {
      if (!snap.exists()) return;
      userData = snap.data();
      document.getElementById('userAvatar').textContent = (userData.fullName || 'S').charAt(0).toUpperCase();
      document.getElementById('userName').textContent = userData.fullName?.split(' ')[0] || 'Staff';
      document.getElementById('userRole').textContent = 'Staff';
      document.getElementById('welcomeName').textContent = userData.fullName?.split(' ')[0] || 'Staff';
      document.getElementById('currentDay').textContent = new Date().toLocaleDateString('en-GB', {weekday:'long', day:'numeric', month:'long'});
      document.getElementById('totalPoints').textContent = userData.totalPoints || 0;
      document.getElementById('leaveDays').textContent = userData.leaveDaysRemaining || 2;
      updateSalaryDisplay();
    }));
    
    // Point value
    unsubscribes.push(onSnapshot(doc(db, 'system_settings', 'points'), (s) => {
      if (s.exists()) globalPointValue = s.data().value || 500;
      updateSalaryDisplay();
    }));
    
    function updateSalaryDisplay() {
      if (!userData) return;
      const ppv = globalPointValue / 5;
      const bonus = (userData.totalPoints || 0) * ppv;
      const final = (userData.baseSalary || 0) + bonus;
      document.getElementById('pointValue').textContent = ppv.toFixed(0);
      document.getElementById('salaryBase').textContent = formatCurrency(userData.baseSalary || 0);
      document.getElementById('salaryPoints').textContent = userData.totalPoints || 0;
      document.getElementById('salaryPointValue').textContent = ppv.toFixed(0);
      document.getElementById('pointsBonus').innerHTML = `<span style="color:${bonus>=0?'#10b981':'#ef4444'}">${bonus>=0?'+':''}${formatCurrency(bonus)}</span>`;
      document.getElementById('finalSalary').textContent = formatCurrency(final);
    }
    
    // Tasks
    const tasksQuery = query(collection(db, 'tasks'), where('assignedTo', '==', currentUser.uid), orderBy('createdAt', 'desc'));
    unsubscribes.push(onSnapshot(tasksQuery, (snap) => {
      const tasks = snap.docs.map(d => ({id: d.id, ...d.data()}));
      const now = new Date();
      const doneThisMonth = tasks.filter(t => t.status === 'completed' && t.submittedAt?.toDate().getMonth() === now.getMonth()).length;
      const pending = tasks.filter(t => t.status !== 'completed').length;
      document.getElementById('tasksDone').textContent = doneThisMonth;
      document.getElementById('pendingTasks').textContent = pending;
      
      // Available tasks (pending)
      const availableDiv = document.getElementById('availableTasks');
      const available = tasks.filter(t => t.status === 'pending');
      availableDiv.innerHTML = available.length ? available.map(t => `
        <div class="task-item">
          <div class="task-info"><h4>${t.title}</h4><p>Deadline: ${formatDate(t.deadline)}</p></div>
          <button class="btn btn-primary btn-sm" onclick="startTask('${t.id}')">Start Task</button>
        </div>`).join('') : '<div class="empty-state"><i class="fas fa-check-circle"></i><p>No pending tasks</p></div>';
      
      // In progress tasks
      const inprogressDiv = document.getElementById('inprogressTasks');
      const inprogress = tasks.filter(t => t.status === 'in_progress');
      inprogressDiv.innerHTML = inprogress.length ? inprogress.map(t => {
        const deadline = t.deadline?.toDate();
        const isUrgent = deadline && (deadline - new Date()) / 86400000 < 1;
        return `<div class="task-item">
          <div class="task-info"><h4>${t.title}</h4><p>Started: ${formatDate(t.startedAt)}</p></div>
          <div style="display:flex;align-items:center;gap:10px;">
            <span class="task-deadline ${isUrgent ? 'urgent' : 'warning'}"><i class="far fa-clock"></i> ${formatDate(t.deadline)}</span>
            <button class="btn btn-success btn-sm" onclick="submitTask('${t.id}')">Submit</button>
          </div>
        </div>`;
      }).join('') : '<div class="empty-state"><i class="fas fa-spinner"></i><p>No tasks in progress</p></div>';
      
      // Completed tasks
      const completedDiv = document.getElementById('completedTasks');
      const completed = tasks.filter(t => t.status === 'completed').slice(0, 5);
      completedDiv.innerHTML = completed.length ? completed.map(t => `
        <div class="task-item">
          <div class="task-info"><h4>${t.title} <i class="fas fa-check-circle" style="color:var(--success);"></i></h4><p>Completed: ${formatDate(t.submittedAt)}</p></div>
          <span class="badge badge-success">+${t.pointsEarned || 0} pts</span>
        </div>`).join('') : '<div class="empty-state"><i class="fas fa-tasks"></i><p>No completed tasks</p></div>';
    }));
    
    // Coin transactions
    const coinQuery = query(collection(db, 'coin_transactions'), where('userId', '==', currentUser.uid), orderBy('createdAt', 'desc'), limit(5));
    unsubscribes.push(onSnapshot(coinQuery, (snap) => {
      const div = document.getElementById('coinTransactionsList');
      if (snap.empty) { div.innerHTML = '<div class="empty-state"><i class="fas fa-coins"></i><p>No transactions yet</p></div>'; return; }
      div.innerHTML = snap.docs.map(d => {
        const t = d.data();
        return `<div class="coin-transaction">
          <div class="coin-info">
            <div class="coin-icon ${t.points>=0?'positive':'negative'}"><i class="fas fa-${t.points>=0?'plus':'minus'}"></i></div>
            <div class="coin-details"><p>${t.reason}</p><small>${formatDate(t.createdAt)}</small></div>
          </div>
          <div class="coin-amount ${t.points>=0?'positive':'negative'}">${t.points>0?'+':''}${t.points} pts</div>
        </div>`;
      }).join('');
    }));
    
    // Attendance
    const attQuery = query(collection(db, 'attendance'), where('userId', '==', currentUser.uid), orderBy('date', 'desc'), limit(5));
    unsubscribes.push(onSnapshot(attQuery, (snap) => {
      const tbody = document.getElementById('attendanceTable'); tbody.innerHTML = '';
      if (snap.empty) { tbody.innerHTML = '<tr><td colspan="3" style="padding:20px;text-align:center;color:var(--gray);">No attendance records</td></tr>'; return; }
      let streak = 0; const dates = snap.docs.map(d => d.data().date).sort().reverse();
      const today = new Date().toISOString().split('T')[0];
      if (dates.length && dates[0] === today) streak = 1;
      for (let i = 1; i < dates.length; i++) { if ((new Date(dates[i-1]) - new Date(dates[i])) / 86400000 === 1) streak++; else break; }
      document.getElementById('attendanceStreak').textContent = streak;
      snap.forEach(d => { const a = d.data(); tbody.innerHTML += `<tr><td style="padding:10px;">${a.date}</td><td style="padding:10px;">${formatTime(a.checkInTime)}</td><td style="padding:10px;"><span class="badge ${a.status==='late'?'badge-warning':'badge-success'}">${a.status}</span></td></tr>`; });
    }));
    
    // Announcements - General
    const generalQuery = query(collection(db, 'announcements'), where('target', 'in', ['all', 'workers']), orderBy('createdAt', 'desc'), limit(5));
    unsubscribes.push(onSnapshot(generalQuery, (snap) => {
      const div = document.getElementById('generalAnnouncements');
      if (snap.empty) { div.innerHTML = '<div class="empty-state"><i class="fas fa-bullhorn"></i><p>No announcements</p></div>'; return; }
      div.innerHTML = snap.docs.map(d => {
        const a = d.data();
        const isRead = a.readBy?.includes(currentUser.uid);
        return `<div class="announcement-card ${!isRead ? 'unread' : ''}" onclick="openAnnouncement('${d.id}')">
          <h4>${!isRead ? '<i class="fas fa-circle" style="color:var(--primary);font-size:0.5rem;"></i>' : ''} ${a.title}</h4>
          <p>${a.message.substring(0, 80)}...</p>
          <div class="meta"><span>From: ${a.sentByName}</span><span>${formatDateTime(a.createdAt)}</span></div>
        </div>`;
      }).join('');
    }));
    
    // Announcements - Personal
    const personalQuery = query(collection(db, 'announcements'), where('recipientIds', 'array-contains', currentUser.uid), orderBy('createdAt', 'desc'), limit(5));
    unsubscribes.push(onSnapshot(personalQuery, (snap) => {
      const div = document.getElementById('personalAnnouncements');
      if (snap.empty) { div.innerHTML = '<div class="empty-state"><i class="fas fa-envelope"></i><p>No personal announcements</p></div>'; return; }
      div.innerHTML = snap.docs.map(d => {
        const a = d.data();
        const isRead = a.readBy?.includes(currentUser.uid);
        return `<div class="announcement-card ${!isRead ? 'unread' : ''}" onclick="openAnnouncement('${d.id}')">
          <h4>${!isRead ? '<i class="fas fa-circle" style="color:var(--primary);font-size:0.5rem;"></i>' : ''} ${a.title}</h4>
          <p>${a.message.substring(0, 80)}...</p>
          <div class="meta"><span>From: ${a.sentByName}</span><span>${formatDateTime(a.createdAt)}</span></div>
        </div>`;
      }).join('');
    }));
  }

  window.startTask = async (taskId) => {
    await updateDoc(doc(db, 'tasks', taskId), { status: 'in_progress', startedAt: serverTimestamp() });
    showToast('Task started!', 'success');
  };

  window.submitTask = async (taskId) => {
    showModal('Submit Task', '<p>Are you sure you want to submit this task?</p><button class="btn btn-success" onclick="confirmSubmitTask(\'' + taskId + '\')">Yes, Submit</button><button class="btn btn-outline" onclick="hideModal()" style="margin-left:10px;">Cancel</button>');
  };

  window.confirmSubmitTask = async (taskId) => {
    hideModal();
    const taskRef = doc(db, 'tasks', taskId);
    const taskSnap = await getDoc(taskRef);
    const task = taskSnap.data();
    const early = new Date() <= task.deadline.toDate();
    const points = early ? 5 : -5;
    
    await updateDoc(taskRef, { status: 'completed', submittedAt: serverTimestamp(), pointsEarned: points });
    await updateDoc(doc(db, 'users', currentUser.uid), { totalPoints: increment(points), tasksCompleted: increment(1) });
    await addDoc(collection(db, 'coin_transactions'), { userId: currentUser.uid, points, reason: task.title, createdAt: serverTimestamp() });
    showToast(`Task submitted! ${points>0?'+':''}${points} points`, 'success');
  };

  window.openAnnouncement = async (id) => {
    const snap = await getDoc(doc(db, 'announcements', id));
    if (!snap.exists()) return;
    const a = snap.data();
    
    // Mark as read
    if (!a.readBy?.includes(currentUser.uid)) {
      await updateDoc(doc(db, 'announcements', id), { readBy: arrayUnion(currentUser.uid) });
    }
    
    let html = `<h4 style="margin-bottom:10px;">${a.title}</h4><p style="margin-bottom:15px;">${a.message}</p><p style="font-size:0.8rem;color:var(--gray);margin-bottom:15px;">From: ${a.sentByName} · ${formatDateTime(a.createdAt)}</p>`;
    
    if (a.requireAcknowledgment && !a.acknowledgedBy?.includes(currentUser.uid)) {
      html += `<button class="btn btn-success" onclick="acknowledgeAnnouncement('${id}')"><i class="fas fa-check"></i> Acknowledge</button>`;
    } else if (a.acknowledgedBy?.includes(currentUser.uid)) {
      html += '<p><i class="fas fa-check-circle" style="color:var(--success);"></i> You have acknowledged this announcement.</p>';
    }
    
    // Reply option
    html += `<div style="margin-top:15px;"><label>Reply (Optional)</label><textarea class="form-control" id="replyMessage" placeholder="Type your reply..."></textarea><button class="btn btn-primary" style="margin-top:10px;" onclick="sendReply('${id}')"><i class="fas fa-reply"></i> Send Reply</button></div>`;
    
    html += '<button class="btn btn-outline" onclick="hideModal()" style="margin-top:15px;width:100%;">Close</button>';
    showModal('Announcement', html);
  };

  window.acknowledgeAnnouncement = async (id) => {
    await updateDoc(doc(db, 'announcements', id), { acknowledgedBy: arrayUnion(currentUser.uid) });
    await addDoc(collection(db, 'announcement_replies'), { announcementId: id, announcementTitle: (await getDoc(doc(db, 'announcements', id))).data().title, userId: currentUser.uid, userName: userData.fullName, type: 'acknowledgment', message: 'Acknowledged', createdAt: serverTimestamp() });
    showToast('Acknowledged', 'success');
    hideModal();
  };

  window.sendReply = async (announcementId) => {
    const message = document.getElementById('replyMessage')?.value.trim();
    if (!message) { showToast('Enter a reply', 'error'); return; }
    const a = (await getDoc(doc(db, 'announcements', announcementId))).data();
    await addDoc(collection(db, 'announcement_replies'), { announcementId, announcementTitle: a.title, userId: currentUser.uid, userName: userData.fullName, type: 'reply', message, createdAt: serverTimestamp() });
    showToast('Reply sent', 'success');
    hideModal();
  };

  window.markAllAnnouncementsRead = async () => {
    const snap = await getDocs(collection(db, 'announcements'));
    const batch = writeBatch(db);
    snap.forEach(d => { if (!d.data().readBy?.includes(currentUser.uid)) batch.update(d.ref, { readBy: arrayUnion(currentUser.uid) }); });
    await batch.commit();
    showToast('All marked as read', 'success');
  };

  document.getElementById('requestLeaveBtn').addEventListener('click', async () => {
    const start = document.getElementById('leaveStart').value, end = document.getElementById('leaveEnd').value;
    if (!start || !end) { showToast('Select dates', 'error'); return; }
    const days = (new Date(end) - new Date(start)) / 86400000 + 1;
    if (days > 2) { showToast('Max 2 days', 'error'); return; }
    if (userData.leaveDaysRemaining < days) { showToast(`Only ${userData.leaveDaysRemaining} days left`, 'error'); return; }
    await addDoc(collection(db, 'leave_requests'), { userId: currentUser.uid, requestedDates: [start, end], status: 'pending', createdAt: serverTimestamp() });
    showToast('Leave requested', 'success');
    document.getElementById('leaveStart').value = document.getElementById('leaveEnd').value = '';
  });

  function cleanupSubscriptions() { unsubscribes.forEach(u => u()); unsubscribes = []; }

  onAuthStateChanged(auth, async (u) => { 
    if (!u) { window.location.href = 'auth.html'; return; } 
    currentUser = u; 
    const data = (await getDoc(doc(db, 'users', u.uid))).data(); 
    if (data.role !== 'staff') { window.location.href = data.role?.includes('admin') ? 'admin-dashboard.html' : 'attendant-dashboard.html'; return; } 
    document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'}); 
    loadDashboard(); 
  });
  
  document.getElementById('logoutBtn').addEventListener('click', () => signOut(auth).then(() => window.location.href='auth.html'));
  window.addEventListener('beforeunload', cleanupSubscriptions);
</script>
</body>
</html>
